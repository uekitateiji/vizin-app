{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@features/*": [
        "features/*"
      ],
      "@shared/*": [
        "shared/*"
      ],
      "@types/*": [
        "@types/*"
      ],
      "@navigation/*": [
        "navigation/*"
      ],
      "@data/*": [
        "data/*"
      ],
      "@assets/*": [
        "../assets/*"
      ]
    }
  }
}